{
  "name": "@real-estate/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start",
    "android": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo run:android",
    "ios": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo run:ios",
    "web": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --web",
    "ios:configure": "npx.cmd --yes eas-cli build:configure",
    "build:apk": "npx.cmd --yes eas-cli build --platform android --profile preview --non-interactive",
    "build:ios": "npx.cmd --yes eas-cli build --platform ios --profile production --non-interactive",
    "ios:testflight": "powershell -ExecutionPolicy Bypass -File ../../scripts/eas-build-ios-testflight.ps1",
    "build:testflight": "powershell -ExecutionPolicy Bypass -File ../../scripts/eas-build-ios-testflight.ps1",
    "download:ios": "powershell -ExecutionPolicy Bypass -File ../../scripts/eas-download-ios-artifact.ps1",
    "submit:ios": "npx.cmd --yes eas-cli submit --platform ios --profile production --non-interactive",
    "submit:ios:latest": "npx.cmd --yes eas-cli submit --platform ios --profile production --latest --non-interactive",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^7.0.14",
    "@real-estate/shared": "1.0.0",
    "expo": "^52.0.0",
    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.0.12",
    "expo-linking": "^7.0.0",
    "expo-router": "^4.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.6.3"
  }
}
